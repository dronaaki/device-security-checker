# AI provider configuration for the "Explain My Results" feature.
# Copy to .env and adjust. All values are optional — with none set, the app
# talks to a local Ollama instance at http://localhost:11434.
#
# ⚠️  SECURITY: Expo inlines every EXPO_PUBLIC_* variable into the JS bundle at
# build time. They are readable by anyone with the web page or the app binary —
# they are NOT secrets. Only put a real API key here for local development.
#
# To ship a cloud provider, leave EXPO_PUBLIC_AI_API_KEY unset and point
# EXPO_PUBLIC_AI_BASE_URL at a backend that holds the key and forwards the
# request. Ollama runs locally and needs no key, which is why it's the default.

# One of: ollama | openrouter | huggingface | anthropic
EXPO_PUBLIC_AI_PROVIDER=ollama

# Defaults per provider: ollama=llama3.2, openrouter=anthropic/claude-opus-4-8,
# huggingface=meta-llama/Llama-3.1-8B-Instruct, anthropic=claude-opus-4-8
# EXPO_PUBLIC_AI_MODEL=llama3.2

# Overrides the provider's endpoint. Set this to your proxy in production.
# EXPO_PUBLIC_AI_BASE_URL=https://your-proxy.example.com/v1

# Local development only. See the security note above.
# EXPO_PUBLIC_AI_API_KEY=
