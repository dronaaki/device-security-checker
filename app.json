{
  "expo": {
    "name": "device-security-checker",
    "slug": "device-security-checker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "devicesecuritychecker",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.anonymous.devicesecuritychecker",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Unhackme audits app camera permissions to detect unauthorized background spying.",
        "NSMicrophoneUsageDescription": "Unhackme audits app microphone permissions to protect your privacy from stealth audio recorders.",
        "NSFaceIDUsageDescription": "Unhackme uses Face ID / Touch ID to securely protect access to your device security logs.",
        "NSLocationWhenInUseUsageDescription": "Unhackme audits location tracking permissions requested by installed apps."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ],
      "package": "com.anonymous.devicesecuritychecker"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-task-manager",
      "expo-background-fetch"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "121adcf1-fc90-4420-813c-fae2344edd08"
      }
    },
    "owner": "niifaels-team"
  }
}
