rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is the Superadmin
    function isSuperadmin() {
      return request.auth != null && request.auth.token.superadmin == true;
    }

    // Check if user is a valid active admin
    function isActiveAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true &&
             (
               !('accessExpiresAtMillis' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) || 
               request.time.toMillis() < get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accessExpiresAtMillis
             );
    }

    // Check if user is deleted
    function isNotDeleted(userId) {
      return request.auth != null && request.auth.uid == userId &&
             (!exists(/databases/$(database)/documents/users/$(userId)) || 
              !('isDeleted' in get(/databases/$(database)/documents/users/$(userId)).data) || 
              get(/databases/$(database)/documents/users/$(userId)).data.isDeleted == false);
    }

    // Users collection: users can read their own doc.
    // Superadmin can read/write all. Admins can read all.
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isSuperadmin() || isActiveAdmin());
      allow write: if request.auth != null && (
        (request.auth.uid == userId && isNotDeleted(userId) && (resource == null || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'role', 'accessExpiresAtMillis', 'isDeleted']))) 
        || isSuperadmin()
      );

      match /securityLogs/{logId} {
        allow read, write: if request.auth != null && ((request.auth.uid == userId && isNotDeleted(userId)) || isSuperadmin());
      }
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && ((request.auth.uid == userId && isNotDeleted(userId)) || isSuperadmin());
      }
      match /ai_conversations/{msgId} {
        allow read, write: if request.auth != null && ((request.auth.uid == userId && isNotDeleted(userId)) || isSuperadmin());
      }
      match /actions/{actionId} {
        allow read, write: if request.auth != null && ((request.auth.uid == userId && isNotDeleted(userId)) || isSuperadmin());
      }
    }

    // Config collection.
    // payment_provider holds live payment secret keys (Stripe/PayPal/Coinbase/etc.)
    // and must never be exposed to time-limited admins — superadmin only.
    // Cloud Functions read it via the Admin SDK, which bypasses these rules.
    // Other config (ai_provider, admin_assistant) stays accessible to active admins.
    match /config/{configId} {
      allow read, write: if isSuperadmin() ||
        (configId != 'payment_provider' && isActiveAdmin() && isNotDeleted(request.auth.uid));
    }

    // AI Incidents collection: any authenticated user can create (mobile app logs failures),
    // but validate shape and limit size to prevent Firestore abuse.
    match /ai_incidents/{incidentId} {
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['timestamp', 'providerId', 'type', 'error', 'source'])
                    && request.resource.data.keys().size() <= 6
                    && request.resource.data.error is string
                    && request.resource.data.error.size() < 2000;
      allow read, delete: if isSuperadmin() || isActiveAdmin();
    }

    // Transactions collection: Superadmin and Active Admins can read, only Superadmin can write
    match /transactions/{transactionId} {
      allow read: if isSuperadmin() || isActiveAdmin();
      allow write: if isSuperadmin();
    }

    // Support tickets: public website can create (no auth required for support form),
    // but validate the schema tightly to prevent abuse.
    match /support_tickets/{ticketId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'message', 'timestamp', 'source'])
                    && request.resource.data.keys().size() <= 5
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() < 200
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 0
                    && request.resource.data.email.size() < 200
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() < 5000
                    && request.resource.data.source is string;
      allow read, update, delete: if isSuperadmin() || isActiveAdmin();
    }

    // Website Content collection: public read, admin write
    match /website_content/{document=**} {
      allow read: if true;
      allow write: if isSuperadmin() || isActiveAdmin();
    }

    // Website Knowledge Base collection (RAG documents from PDF/Word/URL uploads): public read, admin write
    match /website_knowledge_base/{document=**} {
      allow read: if true;
      allow write: if isSuperadmin() || isActiveAdmin();
    }

    // Rate limits collection: managed exclusively by Cloud Functions (admin SDK).
    // No client should read or write these directly.
    match /rate_limits/{docId} {
      allow read, write: if false;
    }
  }
}
